{% extends 'base.html.twig' %}

{% block title %}
    Hello CategoryController!
{% endblock %}

{% block body %}

    <div class="container">
        <section class="categories_container">
            <div class="categories">

                <h1>Liste des catégories</h1>
                {% include 'layouts/_flash_message.html.twig' %}

                <table class="table table-striped">
                    <tr>
                        <th>Nom de la catégorie</th>
                        <th>Action</th>
                    </tr>
                    {% for category in categories %}
                        <tr>
                            <td> {{category.name}} </td>
                            <td>
                                <a href="{{ path('app_category_update', {'id':category.id}) }}" class="btn btn-outline-primary">Modifier</a>
                                <a  href="{{ path('app_category_remove', {'id':category.id}) }}" onclick="return confirm(`Voulez-vous vraiment supprimer cette catégorie ?`)" class="btn btn-danger">Supprimer</a>
                            </td>
                        </tr>
                    {% else %}
                        <p>Aucune catégorie à afficher</p>
                    {% endfor %}
                </table>
                <a href="{{ path('app_category_create') }}" class="btn btn-success">Créer une catégorie</a>
            </div>
        </section>
    </div>
{% endblock %}
