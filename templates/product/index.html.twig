{% extends 'base.html.twig' %}

{% block title %}Product index{% endblock %}

{% block body %}
<div class="container">
    <h1>Liste des produits</h1>
    {% include 'layouts/_flash_message.html.twig' %}

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Sous-catégorie</th>
                <th>Description</th>
                <th>Price</th>
                <th>Stock</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for product in products %}
            <tr>
                <td>{{ product.id }}</td>
                <td>{{ product.name }}</td>
                <td>
                    {% for sub in product.subCategory %}
                        {{sub.name}}
                    {% endfor %}
                </td>
                <td>{{ product.description|slice(0,100) }}</td>
                <td>{{ product.price }} €</td>
                <td>
                    {% if product.stock > 0 %}
                        {{product.stock}}
                        {% else %}
                        <span class="text-danger d-flex flex-nowrap">Stock épuisé</span>
                    {% endif %}
                </td>
                <td class="">
                <div class="d-flex gap-2">
                    <a href="{{ path('app_product_show', {'id': product.id}) }}" class="btn btn-outline-success ">Afficher</a>
                    <a href="{{ path('app_product_edit', {'id': product.id}) }}" class="btn btn-outline-primary">Modifier</a>
                    {{include('/product/_delete_form.html.twig')}}
                    <a href="{{ path('app_product_stock_add', {'id': product.id}) }}" class="btn btn-outline-info">Ajouter du stock</a>
                    </div>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">Aucun produit existant.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_product_new') }}" class="btn btn-success">Créer un nouveau produit</a>
    </div>
{% endblock %}
