{% extends 'base.html.twig' %}

{% block title %}
    Product
{% endblock %}

{% block body %}
    <div class="container">
        <h1>Produit</h1>

        <table class="table">
            <tbody>
                <tr>
                    <th>Id</th>
                    <td>{{ product.id }}</td>
                </tr>
                <tr>
                    <th>Nom</th>
                    <td>{{ product.name }}</td>
                </tr>
                <tr>
                    <th>Catégorie</th>
                    <td>
                        {% for sub in product.subCategory %}
                            {{sub.name}}
                        {% endfor %}
                    </td>
                </tr>
                <tr>
                    <th>Description</th>
                    <td>{{ product.description }}</td>
                </tr>
                <tr>
                    <th>Prix</th>
                    <td>{{ product.price }} €</td>
                </tr>
            </tbody>
        </table>

        <a href="{{ path('app_product_index') }}" class="btn btn-light">Retour aux produits</a>

        <a href="{{ path('app_product_edit', {'id': product.id}) }}" class="btn btn-primary ">Modifier</a>

        <div class="mt-2">
            {{ include('product/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}
