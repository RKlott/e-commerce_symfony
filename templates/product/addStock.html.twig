{% extends 'base.html.twig' %}

{% block title %}Ajout de stock{% endblock %}

{% block body %}
<div class="container">
<h1>Ajout de stock à : <span class="text-danger">{{product.name}}</span> </h1>
{% include 'layouts/_flash_message.html.twig' %}

{{ form_start(form)  }}
{{ form_row(form.quantity, {'attr':{'class':'form form-control mb-3'}}) }}
<input type="submit" class="btn btn-success btn-block">
{{  form_end(form) }}
<a href="{{ path('app_product_index') }}" class="btn btn-light mt-2">Retour aux produits</a>
</div>

{% endblock %}