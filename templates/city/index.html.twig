{% extends 'base.html.twig' %}

{% block title %}City index{% endblock %}

{% block body %}
<div class="container">
    <h1>City index</h1>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>ShippingCost</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for city in cities %}
            <tr>
                <td>{{ city.id }}</td>
                <td>{{ city.name }}</td>
                <td>{{ city.shippingCost }}</td>
                <td>
                    <a href="{{ path('app_city_show', {'id': city.id}) }}" class="btn btn-success">Afficher</a>
                    <a href="{{ path('app_city_edit', {'id': city.id}) }}" class="btn btn-warning">Modifier</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">Aucune ville répertoriée</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_city_new') }}" class="btn btn-primary">Ajouter une ville</a>
    </div>
{% endblock %}
