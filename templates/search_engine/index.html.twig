{% extends 'base.html.twig' %}

{% block title %}
    Hello SearchEngineController!
{% endblock %}

{% block body %}
    <style>
        .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
        .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
    </style>

    <div class="container">
    <h1>Résultat de recherche : {{searchedWord}}</h1>
        {% for product in products %}
            <table class="table table-bordered">
                <tr>
                    <th>Nom</th>
                    <th>Description</th>
                    <th>Prix</th>
                    {# <th>Sous-catégorie</th> #}
                    <th>Image</th>
                    <th>Stock</th>
                </tr>

                <tr>
                    <td> {{product.name}} </td>
                    <td> {{product.description}} </td>
                    <td> {{product.price}} </td>
                    {# <td> {{product.subCategory.category}} </td> #}
                    <td> <img src="{{ asset('uploads/images/'~product.image)}}" class="imgproduct card-img-top" style="width: 14rem;" alt="image des produits"> </td>
                    <td> {{product.stock}} </td>
                </tr>

            </table>
        {% endfor %}
    </div>
{% endblock %}
